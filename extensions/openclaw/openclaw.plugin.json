{
  "id": "denied-openclaw",
  "name": "Denied SDK Hook Plugin for OpenClaw",
  "description": "Enforce authorization before each tool call using the Denied policy engine.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "deniedUrl": { "type": "string" },
      "deniedApiKey": { "type": "string" },
      "failMode": {
        "type": "string",
        "enum": ["open", "closed"],
        "default": "open"
      }
    }
  },
  "uiHints": {
    "deniedUrl": { "label": "Denied base URL" },
    "deniedApiKey": { "label": "Denied API Key", "sensitive": true },
    "failMode": { "label": "Fail mode (open or closed)" }
  }
}
